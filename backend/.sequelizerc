  'models-path': resolve(__dirname, 'src/infrastructure/database/models'),
  'migrations-path': resolve(__dirname, 'src/infrastructure/database/migrations'),
  'seeders-path': resolve(__dirname, 'src/infrastructure/database/seeders'),
};